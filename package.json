{
  "name": "kung_fu_madness",
  "private": true,
  "dependencies": {
    "@hotwired/turbo-rails": "^8.0.23",
    "@rails/actioncable": "^8.1.300",
    "esbuild": "^0.28.1",
    "esbuild-svelte": "^0.9.5",
    "sass": "^1.101.0",
    "svelte": "^5.56.6"
  },
  "scripts": {
    "build:css": "sass ./app/assets/stylesheets/application.sass.scss:./app/assets/builds/application.css --no-source-map --load-path=node_modules",
    "watch:css": "sass ./app/assets/stylesheets/application.sass.scss:./app/assets/builds/application.css --no-source-map --load-path=node_modules --watch",
    "build": "node build.mjs --minify",
    "watch:js": "node build.mjs --watch"
  }
}
