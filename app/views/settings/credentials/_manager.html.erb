<%# Passkey management UI, shared by the settings page and the account panel on
    your own profile. Local: credentials (this user's Credential records). %>
<p>Sign-in keys for your account. Add one per device for fast, passwordless entry.
   Your email link is always a way back in, so you can remove any of these.</p>

<form data-passkey="add-credential"
      data-options-url="<%= options_settings_credentials_path %>"
      data-callback-url="<%= settings_credentials_path %>">
  <p>
    <label for="passkey-nickname" style="font-weight:bold;">Name (optional)</label><br>
    <input id="passkey-nickname" name="nickname" placeholder="e.g. Work laptop" autocomplete="off">
    <button type="submit" class="btn-kfm">Add passkey</button>
  </p>
  <p data-passkey-error style="color: var(--kfm-belt-red);"></p>
</form>

<% if credentials.any? %>
  <table class="stat-table">
    <thead>
      <tr><th>Name</th><th>Added</th><th></th></tr>
    </thead>
    <tbody>
      <% credentials.each do |credential| %>
        <tr>
          <td><%= credential.nickname.presence || "Passkey" %></td>
          <td><%= credential.created_at.to_date.to_fs(:long) %></td>
          <td>
            <%= button_to "Remove", settings_credential_path(credential), method: :delete,
                  class: "btn-kfm",
                  form: { data: { turbo_confirm: "Remove the \"#{credential.nickname.presence || "Passkey"}\" passkey?" } } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p><em>No passkeys yet. Add one above, or keep using email links.</em></p>
<% end %>
