<% content_for :title, "Leaderboard — Kung Fu Madness" %>

<div class="panel-kfm">
  <div class="panel-kfm-title">Top <%= LeaderboardController::TOP_LIMIT %> — all-time XP</div>
  <% if @top.any? %>
    <div class="table-scroll">
      <table class="stat-table">
        <thead>
          <tr><th>#</th><th>Fighter</th><th>XP</th><th>Record</th></tr>
        </thead>
        <tbody>
          <% @top.each_with_index do |fighter, i| %>
            <tr>
              <td class="rank-cell"><%= i + 1 %></td>
              <td><%= fighter_name_link(fighter) %></td>
              <td><%= number_with_delimiter(fighter.xp) %></td>
              <td><%= fighter.record %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p>No fighters have stepped onto the mat yet. The dojo awaits its first legend.</p>
  <% end %>
</div>
