<% content_for :title, "#{@fighter.name} — Kung Fu Madness" %>

<div class="panel-kfm">
  <div class="panel-kfm-title"><%= fighter_display_name(@fighter) %></div>
  <div class="fighter-head">
    <div class="fighter-head__avatar">
      <div class="belt-rect" style="background: <%= belt_var(@fighter.belt) %>;"
           role="img" aria-label="<%= @fighter.belt_name %> belt"></div>
    </div>
    <div class="fighter-head__meta">
      <p class="stat-line"><%= belt_chip(@fighter.belt) %></p>
      <p class="stat-line"><strong><%= @fighter.xp %></strong> XP</p>
      <p class="stat-line">Record: <strong><%= @fighter.record %></strong> (W-L-D)</p>
      <p class="stat-line">Open challenges: <%= @pending_count %></p>
      <p class="stat-line">
        <% if @fighter.online? %>
          <strong class="online-marker">Online now</strong>
        <% elsif @fighter.last_seen_at %>
          Last online <%= time_ago_in_words(@fighter.last_seen_at) %> ago
        <% else %>
          Never seen online
        <% end %>
      </p>

      <% form = @scouting.recent_form %>
      <% if form.any? %>
        <div class="form-strip" aria-label="Recent form, newest first">
          <span class="form-strip__label">Form</span>
          <% form.each do |bout| %>
            <span class="form-box form-box--<%= bout[:result].downcase %>"
                  title="<%= { 'W' => 'Win', 'L' => 'Loss', 'D' => 'Draw' }[bout[:result]] %><%= ' (KO)' if bout[:ko] %>">
              <%= bout[:result] %><% if bout[:ko] %><span class="form-box__ko">*</span><% end %>
            </span>
          <% end %>
        </div>
        <% callout = streak_callout(@scouting.streak) %>
        <% if callout %><p class="stat-line streak-callout"><%= callout %></p><% end %>
      <% end %>

      <% if current_fighter && current_fighter != @fighter %>
        <% state, respond_fight_id = @challenge_state %>
        <p class="stat-line">
          <% if state == :respond %>
            <%= link_to "Respond to #{@fighter.name}", challenge_path(respond_fight_id),
                  class: "btn-kfm", data: { respond_open: respond_fight_id } %>
          <% elsif state == :challenged %>
            <span class="btn-kfm is-disabled" title="Waiting on their answer">Challenge sent</span>
          <% else %>
            <%= link_to "Challenge #{@fighter.name}", new_challenge_path(opponent: @fighter.id),
                  class: "btn-kfm", data: { challenge_open: @fighter.id } %>
          <% end %>
        </p>
      <% end %>
    </div>
  </div>
</div>

<% if @own_profile %>
  <%# Your own match history lives on the dojo homepage, not here. %>
<% else %>
  <div class="panel-kfm">
    <div class="panel-kfm-title">Match history</div>
    <div data-svelte-component="MatchHistory"
         data-props="<%= { fights: @history_rows, fighterId: @fighter.id,
                           viewerId: current_fighter&.id,
                           hideSpoilers: current_user ? current_user.hide_fight_spoilers : false,
                           emptyMessage: "No fights on record yet." }.to_json %>"></div>

    <% if @total_pages > 1 %>
      <div class="page-nav">
        <% if @page > 1 %>
          <%= link_to "← Newer", fighter_path(@fighter, page: @page - 1), class: "btn-kfm" %>
        <% else %>
          <span class="btn-kfm is-disabled">← Newer</span>
        <% end %>
        <span class="page-nav__label">Page <%= @page %> of <%= @total_pages %></span>
        <% if @page < @total_pages %>
          <%= link_to "Older →", fighter_path(@fighter, page: @page + 1), class: "btn-kfm" %>
        <% else %>
          <span class="btn-kfm is-disabled">Older →</span>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>

<% if @own_profile %>
  <% if Push.configured? %>
    <%# Progressive opt-in: hidden until push.js confirms the browser supports it. %>
    <div class="panel-kfm push-alerts" data-push-alerts hidden>
      <div class="panel-kfm-title">Challenge alerts</div>
      <p class="stat-line" data-push-status>Get a notification the moment someone challenges you.</p>
      <button type="button" class="btn-kfm btn-kfm--sm" data-push-enable hidden>Enable notifications</button>
      <button type="button" class="btn-kfm btn-kfm--sm" data-push-disable hidden>Disable</button>
      <label class="push-threshold" data-push-threshold-row hidden>
        Notify only when my pending challenges reach
        <input type="number" inputmode="numeric" min="1" max="1000" step="1"
               value="<%= current_user.push_min_pending_challenges %>" data-push-threshold>
      </label>
    </div>
  <% end %>

  <div class="panel-kfm">
    <div class="panel-kfm-title">Preferences</div>
    <%= form_with url: preferences_path, method: :patch, class: "prefs-form" do |form| %>
      <label class="prefs-row">
        <%= form.check_box :allow_bot_challenges, checked: current_user.allow_bot_challenges %>
        Allow challenges from bots
      </label>
      <label class="prefs-row">
        <%= form.check_box :hide_fight_spoilers, checked: current_user.hide_fight_spoilers %>
        Hide results of my fights until I watch them
      </label>
      <button type="submit" class="btn-kfm btn-kfm--sm">Save</button>
    <% end %>
  </div>

  <div class="panel-kfm">
    <div class="panel-kfm-title">Account</div>
    <p class="stat-line">Email: <strong><%= current_user.email %></strong></p>
    <h3 style="margin: 1rem 0 0.5rem; text-transform: uppercase; letter-spacing: 0.05em;">Passkeys</h3>
    <%= render "settings/credentials/manager", credentials: @credentials %>
  </div>
<% end %>
