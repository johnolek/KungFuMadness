<% content_for :title, "#{@fighter.name} — Kung Fu Madness" %>

<div class="panel-kfm">
  <div class="panel-kfm-title"><%= fighter_display_name(@fighter) %></div>
  <div class="fighter-head">
    <div class="fighter-head__avatar">
      <div class="belt-rect" style="background: <%= belt_var(@fighter.belt) %>;"
           role="img" aria-label="<%= @fighter.belt_name %> belt"></div>
    </div>
    <div class="fighter-head__meta">
      <p class="stat-line"><%= belt_chip(@fighter.belt) %></p>
      <p class="stat-line"><strong><%= @fighter.xp %></strong> XP</p>
      <p class="stat-line">Record: <strong><%= @fighter.record %></strong> (W-L-D)</p>
      <p class="stat-line">Open challenges: <%= @pending_count %></p>

      <% form = @scouting.recent_form %>
      <% if form.any? %>
        <div class="form-strip" aria-label="Recent form, newest first">
          <span class="form-strip__label">Form</span>
          <% form.each do |bout| %>
            <span class="form-box form-box--<%= bout[:result].downcase %>"
                  title="<%= { 'W' => 'Win', 'L' => 'Loss', 'D' => 'Draw' }[bout[:result]] %><%= ' (KO)' if bout[:ko] %>">
              <%= bout[:result] %><% if bout[:ko] %><span class="form-box__ko">*</span><% end %>
            </span>
          <% end %>
        </div>
        <% callout = streak_callout(@scouting.streak) %>
        <% if callout %><p class="stat-line streak-callout"><%= callout %></p><% end %>
      <% end %>

      <% if current_fighter && current_fighter != @fighter %>
        <p class="stat-line">
          <%= link_to "Challenge #{@fighter.name}", new_challenge_path(opponent: @fighter.id),
                class: "btn-kfm", data: { challenge_open: @fighter.id } %>
        </p>
      <% end %>
    </div>
  </div>
</div>

<%= render "fighters/tendencies", scouting: @scouting %>

<div class="panel-kfm">
  <div class="panel-kfm-title">Match history</div>
  <% if @history.any? %>
    <%= render "fights/history_table", fighter: @fighter, fights: @history, show_xp: true %>

    <div class="page-nav">
      <% if @page > 1 %>
        <%= link_to "← Newer", fighter_path(@fighter, page: @page - 1), class: "btn-kfm" %>
      <% else %>
        <span class="btn-kfm is-disabled">← Newer</span>
      <% end %>
      <span class="page-nav__label">Page <%= @page %> of <%= @total_pages %></span>
      <% if @page < @total_pages %>
        <%= link_to "Older →", fighter_path(@fighter, page: @page + 1), class: "btn-kfm" %>
      <% else %>
        <span class="btn-kfm is-disabled">Older →</span>
      <% end %>
    </div>
  <% else %>
    <p>No fights on record yet.</p>
  <% end %>
</div>

<% if @own_profile %>
  <div class="panel-kfm">
    <div class="panel-kfm-title">Account</div>
    <p class="stat-line">Email: <strong><%= current_user.email %></strong></p>
    <h3 style="margin: 1rem 0 0.5rem; text-transform: uppercase; letter-spacing: 0.05em;">Passkeys</h3>
    <%= render "settings/credentials/manager", credentials: @credentials %>
  </div>
<% end %>
