<% content_for :title, "Fighters — Kung Fu Madness" %>

<div class="panel-kfm">
  <div class="panel-kfm-title">The Roster</div>
  <div class="table-scroll">
  <table class="stat-table">
    <thead>
      <tr><th>Fighter</th><th>XP</th><th>Record (W-L-D)</th><th></th></tr>
    </thead>
    <tbody>
      <% @fighters.each do |fighter| %>
        <tr>
          <td><%= fighter_name_link(fighter) %></td>
          <td><%= fighter.xp %></td>
          <td><%= fighter.record %></td>
          <td>
            <% if current_fighter && fighter != current_fighter %>
              <%= link_to "Challenge", new_challenge_path(opponent: fighter.id),
                    class: "btn-kfm btn-kfm--sm", data: { challenge_open: fighter.id } %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  </div>
</div>
