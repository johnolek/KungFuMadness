<% content_for :title, "The Dojo — Kung Fu Madness" %>

<% if @incoming %>
  <div class="panel-kfm">
    <div class="panel-kfm-title">Welcome back, <%= current_fighter.name %></div>
    <p class="stat-line">
      <%= belt_chip(current_fighter.belt) %>
      &middot; <%= current_fighter.xp %> XP
      &middot; Record <%= current_fighter.record %>
      &middot; <%= link_to "View the roster", fighters_path %>
    </p>
  </div>

  <div class="dojo-grid">
    <div class="panel-kfm">
      <div class="panel-kfm-title">Challenges to answer</div>
      <% if @incoming.any? %>
        <% @incoming.each do |fight| %>
          <div class="challenge-row">
            <span>
              <%= belt_chip(fight.challenger_belt) %>
              <%= link_to fight.challenger.name, fighter_path(fight.challenger) %>
            </span>
            <%= link_to "Respond", challenge_path(fight), class: "btn-kfm" %>
          </div>
        <% end %>
      <% else %>
        <p>No one dares challenge you right now.</p>
      <% end %>
    </div>

    <div class="panel-kfm">
      <div class="panel-kfm-title">Challenges you've sent</div>
      <% if @outgoing.any? %>
        <% @outgoing.each do |fight| %>
          <div class="challenge-row">
            <span>
              <%= belt_chip(fight.opponent_belt) %>
              <%= link_to fight.opponent.name, fighter_path(fight.opponent) %>
            </span>
            <span class="result-draw">Awaiting reply…</span>
          </div>
        <% end %>
      <% else %>
        <p>You have no challenges outstanding. <%= link_to "Find an opponent", fighters_path %>.</p>
      <% end %>
    </div>
  </div>

  <div class="panel-kfm">
    <div class="panel-kfm-title">Recent fights across the dojo</div>
    <% if @recent_fights.any? %>
      <table class="stat-table">
        <thead>
          <tr><th>Challenger</th><th>Opponent</th><th>Result</th><th>When</th></tr>
        </thead>
        <tbody>
          <% @recent_fights.each do |fight| %>
            <tr>
              <td><%= link_to fight.challenger.name, fighter_path(fight.challenger) %></td>
              <td><%= link_to fight.opponent.name, fighter_path(fight.opponent) %></td>
              <td>
                <%= link_to fight_path(fight) do %>
                  <% if fight.winner_id.nil? %>
                    Draw<%= " (KO)" if fight.ko %>
                  <% else %>
                    <%= fight.winner.name %> won<%= " by KO" if fight.ko %>
                  <% end %>
                <% end %>
              </td>
              <td><%= time_ago_in_words(fight.resolved_at) %> ago</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p>No fights have been settled yet. Be the first.</p>
    <% end %>
  </div>
<% else %>
  <div class="panel-kfm">
    <div class="panel-kfm-title">The Dojo</div>
    <p>Async rock-paper-scissors kung fu. Send sealed challenges, respond blind,
       and let the dice fall. Scout your rivals' history before you commit.</p>
    <% if signed_in? %>
      <p>Verify your email to step onto the mat — check your inbox for the link.</p>
    <% else %>
      <p><%= link_to "Sign in", login_path, class: "btn-kfm" %>
         <%= link_to "Join the dojo", signup_path, class: "btn-kfm" %></p>
    <% end %>
  </div>
<% end %>
